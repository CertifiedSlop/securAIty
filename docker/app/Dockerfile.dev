# Dockerfile for development with hot reload
FROM python:3.12-slim-bookworm AS base

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV PYTHONFAULTHANDLER=1
ENV PIP_NO_CACHE_DIR=0

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    ca-certificates \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 1000 appgroup \
    && useradd --uid 1000 --gid appgroup --shell /bin/false --create-home appuser


FROM base AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt requirements-dev.txt ./

RUN pip install --prefix=/install -r requirements.txt -r requirements-dev.txt


FROM base AS development

COPY --from=builder /install /usr/local

COPY pyproject.toml .

RUN pip install --no-deps -e .

COPY src/ ./src/
COPY tests/ ./tests/

RUN chown -R appuser:appgroup /app

USER appuser

EXPOSE 8000
EXPOSE 5678

CMD ["-m", "uvicorn", "src.securAIty.api.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "src"]
