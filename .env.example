# Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=securAIty
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/security_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# NATS Streaming
NATS_URL=nats://localhost:4222
NATS_CLUSTER_ID=security-cluster
NATS_CLIENT_ID=security-manager

# HashiCorp Vault
VAULT_URL=http://localhost:8200
VAULT_TOKEN=your-vault-token-here
VAULT_SECRET_PATH=secret/security

# Security
SECRET_KEY=your-secret-key-here
ENCRYPTION_KEY=your-encryption-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=30

# Agent Configuration
AGENT_TIMEOUT_SECONDS=300
AGENT_MAX_CONCURRENT_TASKS=5

# Storage
STORAGE_BACKEND=local
STORAGE_PATH=/tmp/securAIty-storage
MAX_FILE_SIZE_MB=100

# Monitoring
METRICS_ENABLED=True
METRICS_PORT=9090
TRACING_ENABLED=False
TRACING_ENDPOINT=http://localhost:4317

# LLM Provider Configuration
# Provider type: ollama, openrouter, gemini, chatgpt
SECURAITY_LLM_PROVIDER=ollama

# Model selection (defaults based on provider)
# Ollama: qwen2.5:72b, llama3.2, mistral, etc.
# OpenRouter: qwen/qwen-2.5-72b-instruct, openai/gpt-4, etc.
# Gemini: gemini-2.0-flash, gemini-1.5-pro
# ChatGPT: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
SECURAITY_LLM_MODEL=qwen2.5:72b

# LLM parameters
SECURAITY_LLM_MAX_TOKENS=4096
SECURAITY_LLM_TEMPERATURE=0.7
SECURAITY_LLM_TIMEOUT=60.0
SECURAITY_LLM_RETRY_ATTEMPTS=3
SECURAITY_LLM_STREAM=false

# Provider-specific API keys
# Ollama (local, no API key required)
OLLAMA_BASE_URL=http://localhost:11434

# OpenRouter API (get key from https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# Google Gemini API (get key from https://makersuite.google.com)
GEMINI_API_KEY=

# OpenAI ChatGPT API (get key from https://platform.openai.com)
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
